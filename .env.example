DATABASE_URL="mysql://user:password@hostname:3306/wyc_development"
SESSION_SECRET="your-session-secret"
RESEND_API_KEY="re_your_resend_api_key"
VITE_APP_ENV="dev"
# Square — sandbox values in dev (.env.local), production values in prod Vercel env
VITE_SQUARE_APPLICATION_ID="sandbox-sq0idb-xxxxxxxx"
SQUARE_ACCESS_TOKEN="EAAA-your-square-access-token"
SQUARE_LOCATION_ID="Lxxxxxxxxxxxx"
VITE_SQUARE_LOCATION_ID="Lxxxxxxxxxxxx"

# Bearer token Vercel Cron sends to /api/cron/* routes
CRON_SECRET="a-random-string-at-least-16-chars"
